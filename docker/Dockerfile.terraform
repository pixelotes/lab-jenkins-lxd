FROM hashicorp/terraform:latest

# Herramientas para scripts auxiliares (get_vm_ip.sh)
RUN apk add --no-cache bash curl jq

WORKDIR /terraform

# La URL de vmrest se inyecta en tiempo de ejecución via env VMWARE_DESKTOP_URL
# Ejemplo: docker run -e VMWARE_DESKTOP_URL=http://host.docker.internal:8697 ...

ENTRYPOINT ["terraform"]
